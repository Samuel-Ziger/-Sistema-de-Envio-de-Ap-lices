# ====== Servidor ======
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ====== Banco ======
# SQLite (caminho relativo ou absoluto). Em produção aponte para um disco persistente.
DATABASE_URL=sqlite:///./data/envio.db

# ====== Segurança / Auth ======
# Por enquanto o login está DESATIVADO. Quando for ativar, troque AUTH_ENABLED=true
AUTH_ENABLED=false
SECRET_KEY=troque-essa-chave-em-producao-32-bytes-minimo
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Usuário admin criado no primeiro start (seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ====== CORS ======
# Separe por vírgula. Use * só em rede interna.
CORS_ORIGINS=*

# ====== SMTP ======
SMTP_HOST=smtp.seuservidor.com.br
SMTP_PORT=587
SMTP_USER=usuario@empresa.com
SMTP_PASSWORD=suasenha
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=usuario@empresa.com
SMTP_FROM_NAME=Sistema de Envio de Apolices

# Assunto e template padrão
EMAIL_SUBJECT_DEFAULT=Envio de Apolice - {numero_apolice}
EMAIL_TEMPLATE_DEFAULT=templates/email_padrao.html

# ====== Modo FULL ======
FULL_ENABLED=true
FULL_WATCH_FOLDER=./entrada
FULL_SCAN_INTERVAL_SECONDS=30

# ====== Backup ======
BACKUP_FOLDER=./backup

# ====== Pastas de trabalho ======
UPLOAD_FOLDER=./uploads
PROCESSED_FOLDER=./processados
